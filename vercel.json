{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "backend/static/**",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/login",
      "destination": "/backend/static/login.html"
    },
    {
      "source": "/signup",
      "destination": "/backend/static/signup.html"
    },
    {
      "source": "/dashboard",
      "destination": "/backend/static/dashboard.html"
    },
    {
      "source": "/admin",
      "destination": "/backend/static/admin.html"
    },
    {
      "source": "/(.*)",
      "destination": "/backend/static/$1"
    }
  ],
  "env": {
    "PYTHONPATH": "."
  }
}
